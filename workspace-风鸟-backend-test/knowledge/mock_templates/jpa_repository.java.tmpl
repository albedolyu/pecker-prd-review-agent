    @Test
    public void should_return_entity_when_{{METHOD_NAME}}_with_valid_id() {
        // Given
        {{ENTITY_TYPE}} entity = new {{ENTITY_TYPE}}();
        // TODO: 填充实体必填字段
        when({{REPO_FIELD}}.findById(any({{ID_TYPE}}.class))).thenReturn(Optional.of(entity));

        // When
        // {{CUT_FIELD}}.{{METHOD_NAME}}(...);

        // Then
        // assertXxx(...);
        verify({{REPO_FIELD}}).findById(any({{ID_TYPE}}.class));
    }

