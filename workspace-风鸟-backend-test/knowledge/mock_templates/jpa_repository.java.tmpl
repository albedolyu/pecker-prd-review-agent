    // 异常场景组 — exception propagation
    // ------------------------------------------------------------

    @Test(expected = RuntimeException.class)
    public void should_propagate_when_{{METHOD_NAME}}_repo_throws() {
        // Given
        when({{REPO_FIELD}}.findById(any({{ID_TYPE}}.class)))
            .thenThrow(new RuntimeException("db error"));

        // When
        // ...
    }
