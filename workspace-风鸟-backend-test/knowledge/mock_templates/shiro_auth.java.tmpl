*/

// 推荐方案 B: 如果无法重构, 用 ThreadLocal Subject 注入 + tearDown 清理
public class {{CUT_TYPE}}ShiroTest {

    private Subject mockSubject;
    private {{USER_ENTITY}} testUser;

    @Before
    public void setUp() {
        mockSubject = mock(Subject.class);
        testUser = new {{USER_ENTITY}}();
        // TODO: 填充 testUser 必填字段
        // testUser.setId(1L);
        // testUser.setUserName("test");

        when(mockSubject.getPrincipal()).thenReturn(testUser);
        when(mockSubject.isAuthenticated()).thenReturn(true);

        // 注入 ThreadLocal Subject
        org.apache.shiro.util.ThreadContext.bind(mockSubject);
    }

    @org.junit.After
    public void tearDown() {
        // 清理 ThreadLocal, 防止测试间污染
        org.apache.shiro.util.ThreadContext.unbindSubject();
        org.apache.shiro.util.ThreadContext.unbindSecurityManager();
    }

    // ------------------------------------------------------------
    // 已登录用户正常访问
    // ------------------------------------------------------------
    @Test
    public void should_succeed_when_user_authenticated() {
        // Given: setUp 已绑定 mockSubject

        // When
        // Object result = {{CUT_FIELD}}.methodUnderTest(...);

        // Then
        // assertNotNull(result);
        verify(mockSubject).getPrincipal();
    }

    // ------------------------------------------------------------
    // 未登录用户被拒
    // ------------------------------------------------------------
    @Test(expected = org.apache.shiro.authz.UnauthenticatedException.class)
    public void should_throw_when_user_not_authenticated() {
        // Given
        when(mockSubject.isAuthenticated()).thenReturn(false);
        when(mockSubject.getPrincipal()).thenReturn(null);

        // When
        // {{CUT_FIELD}}.methodUnderTest(...);
        // Then: 应抛 UnauthenticatedException
    }

    // ------------------------------------------------------------
    // VIP 用户权限校验
    // ------------------------------------------------------------
    @Test
    public void should_allow_vip_when_user_has_vip_role() {
        // Given
        when(mockSubject.hasRole("vip")).thenReturn(true);

        // When
        // boolean result = {{CUT_FIELD}}.vipOnlyMethod(...);

        // Then
        // assertTrue(result);
    }
}
