// ============================================================
// Mock 模板: Shiro 认证 (风鸟 SecurityUtils.getSubject() 模式)
// ============================================================
// 适用场景: 被测方法调用 SecurityUtils.getSubject() / .getPrincipal() / .isAuthenticated()
// 占位符:
//   {{CUT_TYPE}}       — 被测类
//   {{CUT_FIELD}}      — 被测类字段名
//   {{USER_ENTITY}}    — 用户实体类型, 如 User / UserBase / ShiroUser
//
// 关键约束:
//   1. 风鸟 Shiro realm 返回的 Principal 通常是 User 实体(非 String)
//   2. SecurityUtils 是 static, 用 Mockito.mockStatic (Mockito 3.4+) 或 PowerMock
//   3. 风鸟当前 Mockito 版本较低(Spring Boot 2.1.1 带 Mockito 2.23), 需要走 PowerMock 或重构被测代码
//   4. 更推荐做法: 把 SecurityUtils.getSubject() 封装到 AuthUtils.currentUser() 然后 mock AuthUtils
// ============================================================

import org.apache.shiro.SecurityUtils;
import org.apache.shiro.subject.Subject;
import org.junit.Before;
import org.junit.Test;

import static org.junit.Assert.*;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;

// 推荐方案 A: 重构 — 把 Shiro 调用封装到一个可注入的 AuthContext
// 然后在测试中 mock AuthContext, 这样不需要 PowerMock
