    public void should_return_cached_value_when_key_exists() {
        // Given
        String cacheKey = "riskbird:test:key";
        {{VALUE_TYPE}} cachedValue = null;  // TODO: 构造
        when(valueOperations.get(cacheKey)).thenReturn(cachedValue);

        // When
        // {{VALUE_TYPE}} result = {{CUT_FIELD}}.getFromCache(cacheKey);

        // Then
        // assertEquals(cachedValue, result);
        verify(valueOperations).get(cacheKey);
        // 重要: 确保没有查库, 证明走了缓存
        // verify(databaseRepo, never()).findById(any());
    }

    // ------------------------------------------------------------
    // 缓存未命中 — 降级到数据库
    // ------------------------------------------------------------
    @Test
    public void should_fallback_to_db_when_cache_miss() {
        // Given
        when(valueOperations.get(anyString())).thenReturn(null);
        // 额外 stub 数据库调用(如果有)

        // When
        // {{CUT_FIELD}}.getFromCacheOrDb(...);

        // Then
        verify(valueOperations).get(anyString());
        // verify(databaseRepo).findById(any());
        // verify(valueOperations).set(anyString(), any({{VALUE_TYPE}}.class), anyLong(), any(TimeUnit.class));
    }

    // ------------------------------------------------------------
    // 缓存写入 — 带 TTL
    // ------------------------------------------------------------
    @Test
    public void should_set_cache_with_ttl() {
        // Given
        {{VALUE_TYPE}} value = null;  // TODO

        // When
        // {{CUT_FIELD}}.cacheValue("key", value);

        // Then
        verify(valueOperations).set(anyString(), any({{VALUE_TYPE}}.class), anyLong(), any(TimeUnit.class));
