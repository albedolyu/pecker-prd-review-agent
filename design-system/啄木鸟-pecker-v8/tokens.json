{
  "$meta": {
    "name": "啄木鸟 pecker v8 · design tokens",
    "version": "8.0.0",
    "spec": "design-system/啄木鸟-pecker-v8/MASTER.md",
    "note": "Mirrors tokens.css. Nested by prefix for ergonomics. Apply themes via [data-theme=light|dark]; layer Phase 2 tone with [data-phase2]."
  },
  "themes": {
    "light": {
      "neutral": {
        "0":   "#ffffff",
        "25":  "#fafbfc",
        "50":  "#f4f6f8",
        "100": "#eceff3",
        "150": "#e1e5ea",
        "200": "#d5dae1",
        "300": "#b7bec8",
        "400": "#8f98a3",
        "500": "#6b7380",
        "600": "#4d5561",
        "700": "#343b46",
        "800": "#1f252d",
        "900": "#0e1217"
      },
      "surface": {
        "canvas":      "var(--neutral-25)",
        "raised":      "var(--neutral-0)",
        "sunken":      "var(--neutral-50)",
        "overlay":     "var(--neutral-0)",
        "console":     "#0f1318",
        "console-fg":  "#d4d7dd"
      },
      "text": {
        "strong":   "var(--neutral-800)",
        "default":  "var(--neutral-700)",
        "muted":    "var(--neutral-500)",
        "faint":    "var(--neutral-400)",
        "disabled": "var(--neutral-300)",
        "inverse":  "var(--neutral-0)",
        "link":     "var(--accent-600)"
      },
      "border": {
        "subtle":  "var(--neutral-150)",
        "default": "var(--neutral-200)",
        "strong":  "var(--neutral-300)",
        "focus":   "var(--accent-500)"
      },
      "accent": {
        "50":  "#fff4ec",
        "100": "#ffe3cf",
        "200": "#ffc49b",
        "300": "#ff9f60",
        "400": "#f67b2e",
        "500": "#e8590c",
        "600": "#c7470a",
        "700": "#9e3807",
        "800": "#7a2d08",
        "fg":  "#ffffff"
      },
      "status": {
        "queued":  { "bg": "var(--neutral-100)", "fg": "var(--neutral-500)", "dot": "var(--neutral-400)" },
        "running": { "bg": "var(--accent-50)",   "fg": "var(--accent-600)",  "dot": "var(--accent-500)" },
        "done":    { "bg": "#e6f4ea",            "fg": "#0f6c3a",            "dot": "#10894a" },
        "failed":  { "bg": "#fdecec",            "fg": "#a1241b",            "dot": "#d6352a" },
        "warn":    { "bg": "#fff6dd",            "fg": "#8a5a00",            "dot": "#c78800" },
        "info":    { "bg": "#e5eefb",            "fg": "#184d9e",            "dot": "#2968c8" }
      },
      "fail": {
        "quota":   "#c7470a",
        "tool":    "#a1241b",
        "json":    "#8a5a00",
        "empty":   "#6b7380",
        "timeout": "#184d9e"
      },
      "bird": {
        "1":  "#c7470a",
        "2":  "#184d9e",
        "3":  "#0f6c3a",
        "4":  "#a1241b",
        "5":  "#4d3a86",
        "6":  "#6b7380",
        "7":  "#6b7380",
        "8":  "#6b7380",
        "9":  "#6b7380",
        "10": "#6b7380"
      },
      "shadow": {
        "sm":    "0 1px 1px rgba(15,20,30,.04), 0 1px 2px rgba(15,20,30,.04)",
        "md":    "0 1px 2px rgba(15,20,30,.04), 0 4px 10px rgba(15,20,30,.05)",
        "lg":    "0 2px 4px rgba(15,20,30,.05), 0 12px 28px rgba(15,20,30,.08)",
        "focus": "0 0 0 3px rgba(232,89,12,.22)"
      }
    },
    "dark": {
      "neutral": {
        "0":   "#0b0e12",
        "25":  "#0e1217",
        "50":  "#141921",
        "100": "#1a2028",
        "150": "#212833",
        "200": "#2a323e",
        "300": "#3a4452",
        "400": "#596271",
        "500": "#7a8292",
        "600": "#99a1ae",
        "700": "#bcc2cc",
        "800": "#dde1e7",
        "900": "#f3f5f8"
      },
      "surface": {
        "canvas":      "var(--neutral-25)",
        "raised":      "var(--neutral-50)",
        "sunken":      "var(--neutral-100)",
        "overlay":     "#1b222c",
        "console":     "#06090d",
        "console-fg":  "#c6cbd4"
      },
      "text": {
        "strong":   "var(--neutral-900)",
        "default":  "var(--neutral-800)",
        "muted":    "var(--neutral-500)",
        "faint":    "var(--neutral-400)",
        "disabled": "var(--neutral-300)",
        "inverse":  "#0e1217"
      },
      "border": {
        "subtle":  "var(--neutral-150)",
        "default": "var(--neutral-200)",
        "strong":  "var(--neutral-300)"
      },
      "accent": {
        "50":  "#2a1606",
        "100": "#3f1e08",
        "200": "#6b2d0a",
        "300": "#9a3f0d",
        "400": "#d25712",
        "500": "#f87528",
        "600": "#ff8c4a",
        "700": "#ffa875",
        "fg":  "#0e1217"
      },
      "status": {
        "queued":  { "bg": "var(--neutral-100)", "fg": "var(--neutral-500)", "dot": "var(--neutral-400)" },
        "running": { "bg": "#2a1606",            "fg": "#ffa875",            "dot": "#f87528" },
        "done":    { "bg": "#0f2a19",            "fg": "#5ec784",            "dot": "#2faa5a" },
        "failed":  { "bg": "#2e1312",            "fg": "#ff8579",            "dot": "#e2483b" },
        "warn":    { "bg": "#2a2106",            "fg": "#e9b450",            "dot": "#d89a28" },
        "info":    { "bg": "#10223d",            "fg": "#7aabee",            "dot": "#3e83d8" }
      },
      "fail": {
        "quota":   "#ff8c4a",
        "tool":    "#ff8579",
        "json":    "#e9b450",
        "empty":   "#7a8292",
        "timeout": "#7aabee"
      },
      "bird": {
        "1":  "#ff8c4a",
        "2":  "#7aabee",
        "3":  "#5ec784",
        "4":  "#ff8579",
        "5":  "#b9a3ff",
        "6":  "#7a8292",
        "7":  "#7a8292",
        "8":  "#7a8292",
        "9":  "#7a8292",
        "10": "#7a8292"
      },
      "shadow": {
        "sm":    "0 1px 1px rgba(0,0,0,.3), 0 1px 2px rgba(0,0,0,.25)",
        "md":    "0 1px 2px rgba(0,0,0,.35), 0 4px 10px rgba(0,0,0,.3)",
        "lg":    "0 2px 4px rgba(0,0,0,.4), 0 12px 28px rgba(0,0,0,.45)",
        "focus": "0 0 0 3px rgba(248,117,40,.35)"
      }
    }
  },
  "phase2Overlay": {
    "description": "局部覆盖 · 不改全局 theme · 在 Phase 2 区域根节点加 data-phase2",
    "light": {
      "surface-canvas":  "color-mix(in oklch, var(--neutral-25) 70%, #dce2ec)",
      "surface-raised":  "color-mix(in oklch, var(--neutral-0)  92%, #c7ced9)",
      "surface-sunken":  "color-mix(in oklch, var(--neutral-50) 85%, #c7ced9)",
      "text-default":    "var(--neutral-800)",
      "text-muted":      "var(--neutral-600)",
      "border-default":  "var(--neutral-200)"
    },
    "dark": {
      "surface-canvas":  "#080b10",
      "surface-raised":  "#0f141b",
      "surface-sunken":  "#0a0e13",
      "text-default":    "var(--neutral-900)",
      "text-muted":      "var(--neutral-600)"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "\"Geist\", -apple-system, BlinkMacSystemFont, \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", \"Segoe UI\", system-ui, sans-serif",
      "mono": "\"Geist Mono\", ui-monospace, \"JetBrains Mono\", \"SF Mono\", Menlo, Consolas, monospace"
    },
    "fontSize": {
      "xs":   "11px",
      "sm":   "12px",
      "base": "13px",
      "md":   "14px",
      "lg":   "16px",
      "xl":   "20px",
      "2xl":  "24px",
      "3xl":  "32px"
    },
    "lineHeight": { "tight": 1.25, "normal": 1.5, "loose": 1.65 },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "spacing": {
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px"
  },
  "radius": {
    "0": "0", "1": "2px", "2": "4px", "3": "6px", "4": "8px", "pill": "999px"
  },
  "motion": {
    "ease": {
      "out": "cubic-bezier(.2,.8,.2,1)",
      "in":  "cubic-bezier(.8,.2,1,.8)"
    },
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" }
  },
  "z": { "nav": 20, "drawer": 40, "overlay": 60, "toast": 80 },
  "keyframes": {
    "dot-breathe": "0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.35);opacity:.55}",
    "dot-halo":    "0%{box-shadow:0 0 0 0 rgba(232,89,12,.45)}70%{box-shadow:0 0 0 8px rgba(232,89,12,0)}100%{box-shadow:0 0 0 0 rgba(232,89,12,0)}"
  }
}
