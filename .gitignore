# 敏感文件
.env

# Python 缓存
__pycache__/
*.pyc
*.egg-info/
.venv/
.pytest_cache/

# 运行时产物
output/
logs/

# 会话数据（含用户交互记录）
.sessions/
*.jsonl

# eval 原始结果（不提交）
eval/results/
eval/__pycache__/

# Claude Code 本地产物（草稿 / worktrees / 本地权限配置）
.pecker_drafts/
.claude/worktrees/
.claude/settings.local.json

# 测试缓存
tests/__pycache__/

# pecker-release 旧版缓存
pecker-release/__pycache__/

# workspace 产物中的会话和输出
workspace*/output/
workspace*/.sessions/

# 嵌入的 git 子仓库（wiki 独立管理）
workspace/wiki/

# 百灵代码扫描产物（180k 行 JSON,可由 riskbird_backend_analyzer.py 重建）
workspace*/knowledge/backend_call_graph.json

# Docker Compose 本地夹具(每个开发者的本地部署拓扑可能不同 · 如 api 容器化 vs 宿主机 uvicorn)
docker-compose.override.yml
