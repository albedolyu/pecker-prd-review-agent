# 敏感文件
.env

# Python 缓存
__pycache__/
*.pyc
*.egg-info/
.venv/
.pytest_cache/

# setuptools / pip build 产物 (本地跑 pip install . 时会生成)
build/
dist/
.tmp-pytest/

# 运行时产物
output/
logs/

# 会话数据（含用户交互记录）
.sessions/
*.jsonl

# eval 原始结果（不提交）
eval/results/
eval/__pycache__/

# Claude Code 本地产物（草稿 / worktrees / 本地权限配置）
.pecker_drafts/
.claude/worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# 测试缓存
tests/__pycache__/

# pecker-release 旧版缓存
pecker-release/__pycache__/

# workspace 产物中的会话和输出
workspace*/output/
workspace*/output_*/
workspace*/output_*_run.log
workspace*/.sessions/
workspace*/output_archive_*/

# 真实业务 PRD 工作区（不入公共 repo · workspace-sample 是脱敏 demo,仍可入库）
workspace-fengniao-mediation/
workspace-points-payment/

# 桌面误拖入的业务 docx / Office 锁文件
*.docx
~$*

# 嵌入的 git 子仓库（wiki 独立管理）
workspace/wiki/

# 本地实验运行日志
logs_*.txt

# 百灵代码扫描产物（180k 行 JSON,可由 riskbird_backend_analyzer.py 重建）
workspace*/knowledge/backend_call_graph.json

# Docker Compose 本地夹具(每个开发者的本地部署拓扑可能不同 · 如 api 容器化 vs 宿主机 uvicorn)
docker-compose.override.yml

# STATUS.md 由 CI 每次 push 自动生成 (scripts/generate_status.py) + upload
# artifact. 仓库里跟踪会永远落后真实状态 (2026-04-22 的版本躺在 main 上而数据
# 早已 608+ passed 个测试). 改为 CI artifact-only 作为唯一真相来源, 仓库不再跟踪.
STATUS.md

# 2026-04-29 v2 收尾增补:
# sqlite 运行时数据库 (metrics / learnings / finding_outcomes 都是部署后真数据)
*.db
*.db-shm
*.db-wal

# yaml 备份 (SSOT 迁移工具产物, 不入库避免漂移)
*.yaml.bak

# 临时分析中间文件 (_ 前缀约定 + 工具生成的 *.json 在仓库根)
_*.json
_l3_analysis_*/
_ssot_analysis/
.tmp-demo/
workspace_hardening_demo/

# 回归 baseline 重跑产物 (固定 baseline 在 scripts/fixtures/ 跟踪, 重跑输出忽略)
regression_*.json
regression_real*.json

# workspace 运行时产物 (除已跟踪的 prd/ wiki/ raw/ rules)
workspace-*/learnings/
workspace-*/dashboard.html

# Office 临时锁文件 (Word / Excel 打开时生成)
~$*
