# 啄木鸟 PRD 评审 Agent 配置
# 复制此文件为 .env 并填入实际值

# ====== LLM 后端 ======
# 走本地 Claude Code CLI（零 API key，复用你当前的 CC 登录态）
# 需要先安装 Claude Code 并执行过 `claude login`
USE_CLAUDE_CODE=1

# 评审人（默认 default）
REVIEWER=your-name

# Wiki 知识库路径（可选，默认 workspace/wiki）
WIKI_PATH=

# 飞书通知 Webhook（可选）
FEISHU_WEBHOOK=

# 飞书 Bot（可选，用于飞书机器人接收 PRD 评审）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# GitHub（可选，用于自动提交 PR）
GITHUB_TOKEN=
