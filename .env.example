# 啄木鸟 PRD 评审 Agent 配置
# 复制此文件为 .env 并填入实际值

# Claude API（必填）
ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 评审人（默认 default）
REVIEWER=your-name

# Wiki 知识库路径（可选，默认 workspace/wiki）
WIKI_PATH=

# 飞书通知 Webhook（可选）
FEISHU_WEBHOOK=

# GitHub（可选，用于自动提交 PR）
GITHUB_TOKEN=
