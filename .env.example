# 啄木鸟 PRD 评审 Agent 配置
# 复制此文件为 .env 并填入实际值
# 完整变量说明参考 PRODUCTION_READINESS.md 第五节

# ====== LLM 后端 ======
# 团队上线默认: 走 OpenAI 兼容 API key,避免多人并发挤占个人 CLI/OAT session.
# 不要把真实 sk-* key 提交到 git; 只放部署机服务端 .env.
OPENAI_API_KEY=
# 可选: 多 key 池。团队版建议使用 5-10 个中转 key 分摊 worker 调用。
# 格式: key_1=sk-xxx,key_2=sk-yyy 或直接 sk-xxx,sk-yyy。不要提交真实 key。
OPENAI_API_KEYS=
# 可选: OpenAI 兼容中转地址,例如 https://your-openai-compatible-gateway/v1
OPENAI_BASE_URL=https://pikachu.claudecode.love/v1
# 团队版推荐走 Responses wire,与 Codex provider 配置保持一致
OPENAI_WIRE_API=responses
# 深度评审默认高推理档; worker 单独降一档,避免并行阶段卡在中转超时
OPENAI_REASONING_EFFORT=xhigh
OPENAI_WORKER_REASONING_EFFORT=medium
OPENAI_ADVISOR_REASONING_EFFORT=xhigh
OPENAI_ROUTER_REASONING_EFFORT=medium
# Optional backup route: used when the GPT gateway times out/rate-limits.
# Keep the real key only in the server-side .env, never in git.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING_MODE=auto
# 不把响应存到 OpenAI 侧,降低团队 PRD 数据留存风险
OPENAI_DISABLE_RESPONSE_STORAGE=true
# Team gateway stability knobs: GPT-5.5 deep-review workers can exceed 4 minutes on gateway traffic.
OPENAI_REQUEST_TIMEOUT=420
OPENAI_WORKER_MAX_RETRIES=1
OPENAI_ADVISOR_MAX_RETRIES=2
OPENAI_ROUTER_MAX_RETRIES=1
# 部分中转站会对有效 key 偶发返回 401/invalid_api_key，开启后仅按瞬时网关错误重试，不放宽真实鉴权失败。
PECKER_RETRY_INTERMITTENT_AUTH_401=1
# 预检是增强项,超过该时间就降级为本地资料库扫描,避免首屏长时间等待。
PECKER_PRECHECK_TIMEOUT=90
# 单次上游请求硬超时; 避免中转站悬挂拖住并发队列

# 本地开发兜底: 单人调试时可临时把 model_routes.yaml 的 route 改成 cli 后启用.
# 团队上线不要依赖 CLI/OAT.
USE_CLAUDE_CODE=0

# Anthropic API 直连历史兼容项; 默认 GPT-only 路由不需要填.
API_KEY=

# 评审人（默认 default）
REVIEWER=your-name

# ====== Web 版必需（启动时校验，缺一不启动）======
# 生成：openssl rand -hex 32  或  python -c "import secrets; print(secrets.token_hex(32))"
PECKER_SIGNATURE_SECRET=
PECKER_JWT_SECRET=

# 团队共享登录密码
PECKER_WEB_PASSWORD=

# ====== Web 版可选 ======
# 只读用户列表（逗号分隔，不能归档 / 推送飞书）
# Reconnectable Phase 2 jobs. Keep enabled for team beta so refresh/network
# interruptions can resume the running review instead of forcing a rerun.
NEXT_PUBLIC_REVIEW_JOB_MODE=1
# Internal sample run-diff page. Keep disabled in PM deployments to avoid
# treating demo data as real review history.
NEXT_PUBLIC_ENABLE_INTERNAL_RUNS=0
# Maintainer-only component gallery. Keep disabled in internal PM deployments.
NEXT_PUBLIC_ENABLE_V8_PREVIEW=0
PECKER_READONLY_USERS=

# Figma supplemental material fetch. Put the real token only in server-side .env.
# Also supported alias: PECKER_FIGMA_ACCESS_TOKEN
FIGMA_ACCESS_TOKEN=
FIGMA_FETCH_TIMEOUT=8

# Review assistant Fengniao evidence lookup. All roots are read-only.
# PECKER_FENGNIAO_SOURCE_ROOTS supports semicolon-separated source mirrors.
PECKER_FENGNIAO_WIKI_PATH=
PECKER_FENGNIAO_KNOWLEDGE_PATH=
PECKER_FENGNIAO_SOURCE_ROOTS=

# 管理员用户列表（逗号分隔，bypass workspace ACL,可访问所有 workspace）
# 普通用户只能访问公开 workspace 或 workspace 根目录 .pecker_acl.json 列出自己的
PECKER_ADMIN_USERS=lvxinhang

# Team beta accepts 5-6 users; keep active reviews lower and let extra reviews queue.
PECKER_MAX_CONCURRENT=3
PECKER_MAX_CONCURRENT_MODEL_CALLS=5
# Run deep-review workers in full parallel by default; use 2 only for temporary 2+2 degradation.
PECKER_WORKER_BATCH_SIZE=4
# Keep queued worker calls from timing out before an in-flight deep-review request releases a slot.
PECKER_MODEL_CALL_QUEUE_TIMEOUT=480
# Keep disabled for team beta: a timed-out worker may still be running in the threadpool.
PECKER_ENABLE_WORKER_TIMEOUT_RECOVERY=0
# Keep team beta routes stable; set 1 only when intentionally promoting large PRDs to gpt55.
PECKER_ENABLE_ADAPTIVE_WORKER_PROMOTION=0
# 主评审编排: 默认 langgraph; 如线上异常, 运维可临时改 legacy 并重启服务回滚旧流程.
PECKER_REVIEW_ORCHESTRATOR=langgraph
# 中转站 524/502/504/429 等临时失败时, 单个 worker 用压缩 PRD 视图补跑一次.
PECKER_ENABLE_WORKER_GATEWAY_RECOVERY=1
# PRD 上下文策略: auto=短 PRD 用全文, 大 PRD/恢复重试用结构索引+维度相关摘录; 可改 full 或 packet.
PECKER_PRD_CONTEXT_MODE=auto
# 团队版建议 18KB 以上自动切维度摘录，减少四个 worker 重复塞全文导致的 524。
PECKER_PRD_CONTEXT_AUTO_CHARS=12000
PECKER_PRD_CONTEXT_PACKET_CHARS=12000

# 环境切换: dev / prod / test，默认 dev
PECKER_ENV=dev

# ====== CLI / 非交互模式（run_session.py / post_review.py）======
# 非交互模式(1/true/yes 启用): 跳过需确认的交互,用于 CI / pytest
PECKER_NONINTERACTIVE=
# 自动决策模式: off / accept_all / reject_all,用于批量回归评审
PECKER_AUTO_DECIDE=off
# post_review 自动 push 到远端(1/true/yes 启用,默认需手动确认)
PECKER_AUTO_PUSH=
# 权限模式: NORMAL / auto,auto 模式下非交互环境也强制通过需确认的命令
PECKER_PERMISSION_MODE=

# ====== Wiki ======
# Wiki 知识库路径（可选，默认 workspace/wiki 或 ./shared-wiki）
WIKI_PATH=
# 外部 workspace 根目录。团队 Beta 建议把真实业务 workspace-* 放到内网挂盘,
# 主仓只保留 workspace-sample。Windows 多路径可用英文分号分隔。
PECKER_WORKSPACE_ROOT=
# 外挂 canonical wiki 根目录（可选，递归合并；workspace wiki 优先）
PECKER_EXTERNAL_CANONICAL_WIKI=

# ====== 飞书推送（可选）======
FEISHU_WEBHOOK=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REPORT_CHAT_ID=

# ====== GitHub（可选，自动提交 PR）======
GITHUB_TOKEN=

# ====== 模型路由 / 影子评审（可选）======
# 覆盖默认 model_routes.yaml 路径（灰度/实验用）
PECKER_ROUTES_FILE=
# 等价 --model auto/gpt55/gpt54/gpt54mini，仅覆盖 worker.* 路由
# 留空让 model_routes.yaml 自己分档；临时深度压测时可设 gpt55。
PECKER_MODEL_OVERRIDE=
# 启用 advisor.goshawk.shadow 影子评审（1/true 启用）
PECKER_ENABLE_SHADOW_ADVISOR=0

# ====== NLI / DAR 证据校验调优（可选）======
# 苍鹰 DAR 重采样次数；1/0 等价回退老单次路径
PECKER_GOSHAWK_RESAMPLE=4
# route_eval NLI 矛盾阈值与采样数
PECKER_NLI_CONTRADICT_THRESHOLD=0.3
PECKER_NLI_N_SAMPLES=4
# NLI reason 最短长度、对冲词过滤与 debug dump
PECKER_NLI_REASON_MIN_LEN=15
PECKER_NLI_HEDGING_FILTER=0
PECKER_NLI_DEBUG=0

# ====== Eval / Router 实验开关（可选）======
# 每次 route eval 最多跑多少 case；空值走默认 pattern 限制
PECKER_EVAL_MAX_CASES_PER_RUN=
# router 调试日志与 tool-use 实验路径
PECKER_ROUTER_DEBUG=0
PECKER_ROUTER_TOOL_USE=0
# schema yaml 加载失败时的 dev 逃生口；生产环境不要开启
PECKER_SCHEMA_FALLBACK=0

# ====== 高级调优（有默认值，通常不用改）======
# PECKER_MAX_WORKER_FAILURES=2
# PECKER_MAX_ITEMS_PER_WORKER=15
# GPT-5.5 团队版长上下文配置: 模型上下文约 1M,自动 compact 阈值靠近 900K。
PECKER_MODEL_CONTEXT_WINDOW=1000000
PECKER_COMPACT_THRESHOLD=900000
# PECKER_MAX_WIKI_CHARS=15000
# PECKER_STRICT_YAML=0
# PECKER_WORKER_SOFT_CAP_MULTIPLIER=1.5
# PECKER_WORKER_SEED=
# MAX_BUDGET_USD=0              # 单进程累计成本上限(重启清零),client 层每次模型调用前检查
# 注: GOSHAWK_TIMEOUT 是 config/base.py 里的 Python 常量(非 env),要改直接改代码; 建议 prod 240s

# ====== 成本闸(api/budget_gate.py) ======
# 这些预算会在 /api/review/run 热路径上拦截; 超限直接返回 429,不发起 LLM 调用.
# 0=不限; 内部团队 beta 建议先用保守值,跑两周后按真实使用量调整.
# 单次 review hard cap
PECKER_REVIEW_HARD_CAP_USD=3
# 单人单日 cap
PECKER_REVIEWER_DAILY_BUDGET_USD=30
# 项目单日 cap
PECKER_DAILY_BUDGET_USD=100
# 项目自然月 cap
PECKER_MONTHLY_BUDGET_USD=500
# 预警阈值(0-1), spent >= limit * 此比例时 check_budget 返回的 dict warn=true (当前未 emit 到前端,留接口)
PECKER_BUDGET_WARN_PCT=0.8

# ====== 规则权重时间衰减(rule_perf_decay.py) ======
# rule_performance_history 里的 impact_score 按半衰期向 neutral(0.5) 衰减.
# 2 个月前的 reject 和昨天的 reject 不应同权重, 老数据慢慢回归"不知道".
# 默认 90 天 = 3 个月内的 PM 决策仍有较强权重, 老数据逐步衰减. 上线数据稳定后可调.
# 0 或负数 = 不衰减(退化为原 EMA).
PECKER_RULE_HALF_LIFE_DAYS=90
