# 啄木鸟 PRD 评审 Agent

# API Key（必填，向 PM 索取）
ANTHROPIC_API_KEY=

# 中转站地址（必填）
ANTHROPIC_BASE_URL=https://pikachu.claudecode.love

# API 格式：anthropic（原生）/ openai（兼容）
API_MODE=anthropic

# 共享知识库路径（必填）
# 先 clone: git clone https://github.com/xinshu001/prd-wiki.git
# 然后填本地路径
WIKI_PATH=

# 评审人姓名（必填）
REVIEWER=你的名字

# GitHub Token（可选，用于 /submit）
GITHUB_TOKEN=

# 飞书通知（可选）
FEISHU_WEBHOOK=
