# 啄木鸟 PRD 评审 Agent

# 团队上线 API Key（必填，仅放服务端 .env，不发给前端/同事）
OPENAI_API_KEY=

# OpenAI 兼容中转地址（可选）
OPENAI_BASE_URL=https://pikachu.claudecode.love

# 团队版 GPT 路由
OPENAI_WIRE_API=responses
OPENAI_REASONING_EFFORT=xhigh
OPENAI_DISABLE_RESPONSE_STORAGE=true
PECKER_MODEL_OVERRIDE=
PECKER_MODEL_CONTEXT_WINDOW=1000000
PECKER_COMPACT_THRESHOLD=900000

# 成本闸：超限会在评审前拒绝，避免反复重试烧预算
PECKER_REVIEW_HARD_CAP_USD=3
PECKER_REVIEWER_DAILY_BUDGET_USD=30
PECKER_DAILY_BUDGET_USD=100
PECKER_MONTHLY_BUDGET_USD=500

# 共享知识库路径（必填）
# 先 clone: git clone https://github.com/xinshu001/prd-wiki.git
# 然后填本地路径
WIKI_PATH=

# 评审人姓名（必填）
REVIEWER=你的名字

# GitHub Token（可选，用于 /submit）
GITHUB_TOKEN=

# 飞书通知（可选）
FEISHU_WEBHOOK=
